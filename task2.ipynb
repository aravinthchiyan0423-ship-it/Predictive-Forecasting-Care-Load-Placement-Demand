# data_prep.py
# -----------------------------------------------------------------------------
# Run this ONCE (or whenever the raw CSV updates) to clean the raw HHS UAC data
# and save a ready-to-use processed file: uac_data_processed.csv
#
# app.py reads ONLY uac_data_processed.csv — it does NOT read the raw file.
# So if you update the raw data, re-run this script before refreshing app.py.
# -----------------------------------------------------------------------------

import pandas as pd
import numpy as np

# ===== EDIT THIS to your raw CSV path =====
RAW_PATH = r"D:\A Aravinth\HHS_Unaccompanied_Alien_Children_Program\HHS_Unaccompanied_Alien_Children_Program.csv"
OUTPUT_PATH = "uac_data_processed.csv"
# ===========================================

print("Loading raw data...")
df = pd.read_csv(RAW_PATH)

# Drop fully-empty trailing rows (the raw export has blank rows at the bottom)
df = df.dropna(how="all")

# Parse dates and set as index
df["Date"] = pd.to_datetime(df["Date"])
df = df.sort_values("Date").set_index("Date")

# Clean numeric columns (strip commas, coerce to numeric)
numeric_cols = [
    "Children apprehended and placed in CBP custody*",
    "Children in CBP custody",
    "Children transferred out of CBP custody",
    "Children in HHS Care",
    "Children discharged from HHS Care",
]
for col in numeric_cols:
    df[col] = df[col].astype(str).str.replace(",", "").str.strip()
    df[col] = pd.to_numeric(df[col], errors="coerce")

# Fill small gaps via time-based interpolation, then back/forward fill any edges
for col in numeric_cols:
    df[col] = df[col].interpolate(method="time").bfill().ffill()

print("Missing values after cleaning:")
print(df[numeric_cols].isnull().sum())

# ----- Feature Engineering -----
df["Net_Pressure"] = df["Children transferred out of CBP custody"] - df["Children discharged from HHS Care"]

for col in ["Children in HHS Care", "Net_Pressure"]:
    df[f"{col}_lag1"] = df[col].shift(1)
    df[f"{col}_lag7"] = df[col].shift(7)
    df[f"{col}_lag14"] = df[col].shift(14)

df["CareLoad_roll7_mean"] = df["Children in HHS Care"].rolling(7).mean()
df["CareLoad_roll7_std"] = df["Children in HHS Care"].rolling(7).std()
df["CareLoad_roll14_mean"] = df["Children in HHS Care"].rolling(14).mean()
df["CareLoad_roll14_std"] = df["Children in HHS Care"].rolling(14).std()

df["day_of_week"] = df.index.dayofweek
df["month"] = df.index.month
df["is_weekend"] = df["day_of_week"].isin([5, 6]).astype(int)

# Save — KEEP the early NaN rows (from lag/rolling windows); app.py drops them
# only for model training, but keeps full history for the trend charts.
df.index.name = "Date"
df.to_csv(OUTPUT_PATH, index=True)

print(f"\nSaved cleaned + feature-engineered data to: {OUTPUT_PATH}")
print(f"Shape: {df.shape}")
print(f"Date range: {df.index.min().date()} to {df.index.max().date()}")
